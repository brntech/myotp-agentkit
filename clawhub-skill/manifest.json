{
  "$schema": "https://clawhub.ai/schemas/skill-manifest-v1.json",
  "name": "myotp-otp",
  "display_name": "MyOTP.App",
  "description": "Add SMS, WhatsApp, or Telegram OTP / 2FA / MFA / phone verification to any app using MyOTP.App. Two-endpoint REST API with a single X-API-Key header. Use when the user asks for SMS OTP, 2FA, signup phone verification, password reset codes, transaction step-up auth, or wants a Twilio Verify, Vonage Verify, or Firebase Phone Auth alternative.",
  "version": "1.0.0",
  "author": "BroadNet Technologies",
  "author_email": "info@myotp.app",
  "license": "MIT",
  "homepage": "https://myotp.app",
  "repository": "https://github.com/brntech/myotp-agentkit",
  "documentation": "https://myotp.app/api-reference/",
  "tags": [
    "sms",
    "otp",
    "verification",
    "2fa",
    "mfa",
    "authentication",
    "phone",
    "whatsapp",
    "telegram",
    "twilio-alternative",
    "vonage-alternative",
    "firebase-phone-auth",
    "one-time-password",
    "phone-verification",
    "broadnet"
  ],
  "categories": [
    "authentication",
    "communication",
    "security"
  ],
  "requires": {
    "env": ["MYOTP_API_KEY"],
    "bins": ["curl"],
    "primary_env": "MYOTP_API_KEY"
  },
  "external_services": [
    {
      "name": "MyOTP.App API",
      "base_url": "https://api.myotp.app",
      "auth": "X-API-Key header",
      "documentation": "https://myotp.app/api-reference/"
    }
  ],
  "pricing_model": "external",
  "pricing_notes": "Free trial: 15 messages. Starter $20/mo, Business $25/mo, Enterprise custom. Per-message cost varies by destination country and channel.",
  "security": {
    "obfuscated_code": false,
    "external_network_calls": ["https://api.myotp.app"],
    "installer_hooks": false,
    "binary_dependencies": ["curl"],
    "audit_url": "https://github.com/brntech/myotp-agentkit/tree/main/clawhub-skill"
  }
}
