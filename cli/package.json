{
  "name": "@myotp/cli",
  "version": "0.1.2",
  "description": "MyOTP.App command line interface. Save an API key, send OTPs, verify codes, and check account status from your terminal or AI agent.",
  "license": "MIT",
  "author": "BroadNet Technologies <info@myotp.app>",
  "homepage": "https://myotp.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/brntech/myotp-agentkit.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/brntech/myotp-agentkit/issues"
  },
  "keywords": [
    "myotp",
    "otp",
