{
  "name": "@myotp/mcp",
  "version": "0.1.1",
  "description": "Model Context Protocol server for MyOTP.App — send and verify OTPs (SMS, WhatsApp, Telegram) from any MCP-compatible AI agent.",
  "license": "MIT",
  "author": "BroadNet Technologies <info@myotp.app>",
  "homepage": "https://myotp.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/brntech/myotp-agentkit.git",
    "directory": "mcp-server"
  },
  "bugs": {
    "url": "https://github.com/brntech/myotp-agentkit/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "myotp",
    "otp",
    "2fa",
    "sms",
    "whatsapp",
    "telegram",
    "verification",
    "claude",
    "cursor",
    "windsurf",
    "ai-agent"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "myotp-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc -w -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
